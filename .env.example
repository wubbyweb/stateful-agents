# ============================================================================
# Environment Variables for the Multi-Agent Research System
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You can get an OpenAI API key at: https://platform.openai.com/api-keys
# Note: The system supports --dry-run mode which does NOT require an API key.
# ============================================================================

OPENAI_API_KEY=your-api-key-here

# ── Azure Cosmos DB (MongoDB API) ─────────────────────────────────
# Used for durable long-term and episodic memory persistence.
# Create a Cosmos DB account with the MongoDB API, then copy the
# connection string from the Azure portal → Settings → Connection String.
# Leave blank to use local-only fallback storage.
# ============================================================================
AZURE_COSMOS_CONNECTION_STRING=
AZURE_COSMOS_DATABASE=agent_memory

# ── Azure Cache for Redis ─────────────────────────────────────────
# Used as an ultra-low-latency cache for short-term working memory.
# Create an Azure Cache for Redis instance, then copy the Host name
# and Primary Key from the Azure portal → Settings → Access keys.
# Leave blank to use local-only fallback storage.
# ============================================================================
AZURE_REDIS_HOST=
AZURE_REDIS_PORT=6380
AZURE_REDIS_PASSWORD=
AZURE_REDIS_SSL=true
